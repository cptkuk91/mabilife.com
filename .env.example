# MongoDB
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/mabilife?retryWrites=true&w=majority
MONGODB_AUTH_URL=mongodb+srv://username:password@cluster.mongodb.net/auth?retryWrites=true&w=majority

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your_bucket_name
NEXT_PUBLIC_CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# Google Analytics
NEXT_PUBLIC_GA_ID=your_ga_id

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key

# Redis (optional)
USE_REDIS=false
REDIS_PREFIX=mb
REDIS_URL=redis://default:password@host:port
